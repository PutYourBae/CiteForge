# CiteForge — Environment Variables
# Copy this file to .env and fill in values you want to enable.
# All values here are OPTIONAL — the app works without any of them.

# ── AI / LLM (optional) ─────────────────────────────────────
# Tier 2: Ollama runs locally, no key needed — just install Ollama separately
# https://ollama.com/

# Tier 3: Cloud AI (uncomment to enable)
# VITE_GEMINI_API_KEY=your_google_ai_studio_key_here
# VITE_OPENAI_API_KEY=your_openai_key_here

# ── Academic APIs (optional) ────────────────────────────────
# These are free APIs — no keys required for basic usage
# VITE_SEMANTIC_SCHOLAR_KEY=   # For >100 req/s rate limit
# VITE_CORE_API_KEY=           # CORE search (free registration)

# ── Dev / Build ──────────────────────────────────────────────
# NODE_ENV=development
